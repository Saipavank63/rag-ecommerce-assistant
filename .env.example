# ── RAG E-Commerce Assistant — Environment Variables ──────────────────────────
# Copy this file to .env and fill in the values before running docker-compose up.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ai-assistant-group
KAFKA_ORDER_TOPIC=order-events
KAFKA_PRODUCT_TOPIC=product-events

# ── PostgreSQL (Order Service) ────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ecommerce
SPRING_DATASOURCE_USERNAME=ecommerce
SPRING_DATASOURCE_PASSWORD=ecommerce

# ── Weaviate (Vector Store) ──────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8081
WEAVIATE_COLLECTION=Product

# ── Service URLs (for inter-service communication) ───────────────────────────
ORDER_SERVICE_URL=http://localhost:8080

# ── RAG Configuration ────────────────────────────────────────────────────────
SIMILARITY_TOP_K=5
HYBRID_ALPHA=0.5
